# GPU Fleet Failure Classifier — environment configuration
# Copy this file to .env and fill in values for your deployment.
# All values shown are the defaults used when a variable is unset.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_DB=fleetdb
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet123        # change this in production

# ---------------------------------------------------------------------------
# Classifier behaviour
# ---------------------------------------------------------------------------

# CLASSIFIER_MODE
#   poll  — runs every RUN_INTERVAL seconds (simulator and fallback mode)
#   hook  — single-shot, triggered per job by the Slurm epilog script
CLASSIFIER_MODE=poll

# SACCT_FORMAT
#   auto       — detect format automatically (recommended)
#   simulator  — flat JSON array written by sacct_sim.py
#   real       — native sacct --json output (Slurm 21.08+)
SACCT_FORMAT=auto

# How often the classifier polls in poll mode (seconds)
RUN_INTERVAL=900

# ---------------------------------------------------------------------------
# Prometheus / DCGM
# ---------------------------------------------------------------------------

# URL of your Prometheus instance.
# For the built-in stack: http://prometheus:9090
# For a real cluster: https://prometheus.your-cluster.internal
REAL_PROMETHEUS_URL=http://prometheus:9090

# Label name used for hostname in DCGM metrics.
# Check with: curl -s http://<prometheus>/api/v1/label/__name__/values | grep DCGM
# then: curl -s 'http://<prometheus>/api/v1/series?match[]=DCGM_FI_DEV_GPU_TEMP'
# Common values: hostname (default), Hostname, instance
DCGM_HOSTNAME_LABEL=hostname

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GF_ADMIN_PASSWORD=admin           # change this in production

# ---------------------------------------------------------------------------
# Real cluster log mount (prod overlay only)
# ---------------------------------------------------------------------------
# Path on the Docker host that contains slurmctld.log, slurmd.log,
# and sacct_data.json (written by adapt_sacct.py or the epilog hook).
LOG_MOUNT=/var/log/slurm
